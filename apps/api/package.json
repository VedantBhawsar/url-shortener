{
  "name": "url-shortener",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "type": "commonjs",
  "private": true,
  "scripts": {
    "start": "node dist/index.js",
    "dev": "bun run ./index.ts --watch",
    "prepare": "husky",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "oxlint --config oxlint.json .",
    "build": "tsc --project tsconfig.json --outDir dist --noEmit false",
    "postinstall": "npx prisma generate"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "oxlint --config oxlint.json",
      "prettier --write"
    ],
    "*.{json,md,yaml,yml}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/bun": "latest",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/dotenv": "^8.2.3",
    "@types/express": "^5.0.6",
    "@types/geoip-lite": "^1.4.4",
    "@types/node": "^25.3.3",
    "@types/ua-parser-js": "^0.7.39",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "oxlint": "^1.51.0",
    "prettier": "^3.8.1",
    "prisma": "^7.4.2"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.4.2",
    "@prisma/client": "^7.4.2",
    "@types/compression": "^1.8.1",
    "bcrypt": "^6.0.0",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "geoip-lite": "^2.0.1",
    "jose": "^6.1.3",
    "lru-cache": "^11.2.6",
    "redis": "^5.11.0",
    "stripe": "^21.0.1",
    "ua-parser-js": "^2.0.9",
    "zod": "^4.3.6"
  }
}
